# EditorConfig: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 88

[*.py]
indent_size = 4
max_line_length = 88

[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

[*.{html,css,scss}]
indent_size = 2
max_line_length = 120

[*.{json,yml,yaml,toml}]
indent_size = 2
max_line_length = 120

[*.md]
trim_trailing_whitespace = false
max_line_length = 100

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 2

[*.{ini,cfg}]
indent_size = 4

# 项目特定配置
[excel/*.xlsx]
# Excel文件不需要编辑配置

[scripts/*.sh]
indent_style = tab
indent_size = 4

[tests/*.py]
# 测试文件可以放宽一些限制
max_line_length = 100