{
  "id": "wuni_xiaohua",
  "name": "污泥消化池",
  "version": "5.1.0",
  "author": "Graduation Design Team",
  "description": "厌氧污泥消化池，降解挥发性有机物(VS)，产生沼气。中温消化(35°C)。",
  "category": "市政污水处理",
  "icon": "🔥",
  "node_type": "wuni_xiaohua",
  "process_stage": "sludge",
  "node_class": "WuniXiaohuaNode",
  "module_path": "",
  "inputs": [
    {
      "type": "SLUDGE",
      "name": "污泥进"
    }
  ],
  "outputs": [
    {
      "type": "SLUDGE",
      "name": "消化污泥"
    }
  ],
  "parameters": [
    {
      "key": "n",
      "symbol": "n",
      "name": "池数量",
      "unit": "座",
      "default": 2,
      "min": 1,
      "max": 4,
      "step": 1,
      "description": "消化池数量"
    },
    {
      "key": "T_digest",
      "symbol": "T_d",
      "name": "消化温度",
      "unit": "°C",
      "default": 35,
      "min": 30,
      "max": 55,
      "step": 1,
      "description": "中温35°C或高温55°C"
    },
    {
      "key": "theta_digest",
      "symbol": "θ",
      "name": "消化时间",
      "unit": "d",
      "default": 20,
      "min": 15,
      "max": 30,
      "step": 1,
      "description": "污泥消化停留时间"
    },
    {
      "key": "eta_VS",
      "symbol": "η_vs",
      "name": "VS降解率",
      "unit": "-",
      "default": 0.45,
      "min": 0.3,
      "max": 0.6,
      "step": 0.05,
      "description": "挥发性固体降解率"
    },
    {
      "key": "biogas_rate",
      "symbol": "r_gas",
      "name": "产气率",
      "unit": "m³/kgVS",
      "default": 0.9,
      "min": 0.7,
      "max": 1.0,
      "step": 0.05,
      "description": "单位VS降解产沼气量 (0.8~1.0)"
    }
  ],
  "removal_rates": {},
  "formula": "V = Q_wet × θ / n",
  "formula_detail": "V:单池容积(m³) Q_wet:湿污泥量(m³/d) θ:消化时间(d) n:池数",
  "dependencies": [],
  "tags": [
    "污泥处理",
    "厌氧消化",
    "沼气"
  ],
  "references": [
    "GB50014-2021 §7.3",
    "CJJ 131-2009"
  ],
  "elevation_loss": {
    "value": 0.4,
    "formula": "经验值: 0.4m"
  }
}
